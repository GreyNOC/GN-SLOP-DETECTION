{
  "name": "gn-slop-detection-desktop",
  "version": "0.2.2",
  "description": "GreyNOC Slop Detection desktop app",
  "main": "electron/main.js",
  "private": true,
  "author": "GreyNOC",
  "license": "MIT",
  "scripts": {
    "start": "node scripts/run-electron.js",
    "dev": "node scripts/run-electron.js",
    "gn": "node scripts/run-cli.js",
    "cli": "node scripts/run-cli.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win nsis portable",
    "build:win:inno": "powershell -ExecutionPolicy Bypass -File scripts/build-inno-windows.ps1",
    "build:mac": "electron-builder --mac dmg zip",
    "build:linux": "electron-builder --linux AppImage deb tar.gz",
    "compile:win": "powershell -ExecutionPolicy Bypass -File scripts/compile-windows.ps1",
    "compile:mac": "bash scripts/compile-mac.sh",
    "compile:linux": "bash scripts/compile-linux.sh",
    "release:win": "powershell -ExecutionPolicy Bypass -File scripts/compile-windows.ps1",
    "release:win:inno": "powershell -ExecutionPolicy Bypass -File scripts/build-inno-windows.ps1",
    "release:mac": "bash scripts/compile-mac.sh",
    "release:linux": "bash scripts/compile-linux.sh"
  },
  "devDependencies": {
    "electron": "39.2.6",
    "electron-builder": "26.0.12"
  },
  "build": {
    "appId": "com.greynoc.slopdetection",
    "productName": "GreyNOC Slop Detection",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/desktop-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "GreyNOC-Slop-Detection-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GreyNOC Slop Detection"
    },
    "portable": {
      "artifactName": "GreyNOC-Slop-Detection-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Utility"
    }
  }
}
